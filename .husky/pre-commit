#!/usr/bin/env sh

echo ""
echo "================================================="
echo " ⏳ Running pre-commit formatting & linting..."
echo "================================================="

# FORCE_COLOR=1 ensures the text remains colored inside VS Code's Git output
FORCE_COLOR=1 bunx lint-staged || exit 1

echo ""
echo "================================================="
echo " ⏳ Running typecheck..."
echo "================================================="
bun run typecheck || exit 1

echo ""
echo "================================================="
echo " ⏳ Running build..."
echo "================================================="
bun run build || exit 1

echo ""
echo "================================================="
echo " ✅ All checks passed!"
echo "================================================="
